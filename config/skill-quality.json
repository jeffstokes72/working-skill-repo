{
  "schema_version": 1,
  "runtimes": {
    "codex": {
      "label": "Codex",
      "instruction_surfaces": {
        "AGENTS.md": "supported",
        ".github/copilot-instructions.md": "warning-only",
        ".github/instructions/*.instructions.md": "warning-only",
        ".github/skills/**/SKILL.md": "supported"
      },
      "skill_directories": {
        ".github/skills": "supported",
        "~/.codex/skills": "supported",
        "~/.agents/skills": "supported"
      },
      "agents": "supported",
      "scripts": "supported",
      "eval_modes": {
        "static": "supported",
        "fixture": "supported",
        "live_model": "supported-explicit"
      }
    },
    "ghcp": {
      "label": "GitHub Copilot",
      "instruction_surfaces": {
        "AGENTS.md": "supported",
        ".github/copilot-instructions.md": "supported",
        ".github/instructions/*.instructions.md": "supported",
        ".github/skills/**/SKILL.md": "supported"
      },
      "skill_directories": {
        ".github/skills": "supported",
        "~/.copilot/skills": "supported",
        "~/.agents/skills": "supported"
      },
      "agents": "supported",
      "scripts": "supported",
      "eval_modes": {
        "static": "supported",
        "fixture": "supported",
        "live_model": "supported-explicit"
      }
    }
  },
  "lint": {
    "skill_root": ".github/skills",
    "agent_root": ".github/agents",
    "require_argument_hint": "warning",
    "required_frontmatter": [
      "name",
      "description"
    ],
    "scan_extensions": [
      ".md",
      ".ps1",
      ".json",
      ".yaml",
      ".yml"
    ],
    "hot_path_warning_lines": 250,
    "hot_path_fail_lines": 450,
    "allow_long_skills": {
      "kb-brainstorm": "2026-06-10 rent audit plus runtime-boundary update: judgment and scope content remains inline; deterministic phase/gate proof rules are migrating to kbcheck manifest-contract/gate-ledger; 400 lines is a review trigger, not a trim target.",
      "kb-plan": "2026-06-10 rent audit plus runtime-boundary update: judgment, source normalization, and slice design guidance remains inline; deterministic manifest/gate proof rules are migrating to kbcheck manifest-contract/gate-ledger.",
      "kb-map-bootstrap": "bootstrap coverage tactics are intentionally detailed",
      "kb-work": "2026-06-10 rent audit plus runtime-boundary update: judgment, safety, scope, and escalation guidance remains inline; deterministic terminal-state/gate proof rules are migrating to kbcheck manifest-contract/gate-ledger.",
      "ce-compound": "inherited compound-engineering workflow with large output contract"
    }
  },
  "route_complexity": {
    "fixture_root": "evals/route-complexity",
    "allowed_platforms": [
      "codex",
      "ghcp",
      "both"
    ],
    "allowed_routes": [
      "kb-fix",
      "kb-troubleshoot",
      "kb-brainstorm",
      "kb-plan",
      "kb-work",
      "kb-goal",
      "kb-epic",
      "kb-architecture-deepening",
      "kb-ship",
      "kb-finish",
      "kb-complete",
      "kb-finalize",
      "kb-land",
      "kb-review",
      "kb-research"
    ],
    "rubric": {
      "small_max": 4,
      "standard_max": 13,
      "large_min": 14
    }
  },
  "skill_eval": {
    "selftest_result_root": "evals/skill-eval/selftest",
    "result_schema_version": 1,
    "claim_check_types": [
      "file_exists",
      "command_ran",
      "file_read"
    ]
  },
  "review_reference_guard": {
    "shared_pairs": [
      {
        "id": "review-diff-scope",
        "left": ".github/skills/ce-review/references/diff-scope.md",
        "right": ".github/skills/kb-review/references/diff-scope.md",
        "owner": "review-skill-maintainers",
        "reason": "Primary, secondary, and pre-existing diff-scope doctrine is intentionally shared by CE and KB review."
      },
      {
        "id": "review-resolve-base",
        "left": ".github/skills/ce-review/references/resolve-base.sh",
        "right": ".github/skills/kb-review/references/resolve-base.sh",
        "owner": "review-skill-maintainers",
        "reason": "Fork-safe review-base detection must stay identical for CE and KB review."
      }
    ],
    "intentional_forks": [
      {
        "id": "review-skill-entrypoints",
        "left": ".github/skills/ce-review/SKILL.md",
        "right": ".github/skills/kb-review/SKILL.md",
        "owner": "review-skill-maintainers",
        "reason": "Public entry points stay separate: ce-review is the generalized CE lane; kb-review is the KB completion lane."
      },
      {
        "id": "review-findings-schema",
        "left": ".github/skills/ce-review/references/findings-schema.json",
        "right": ".github/skills/kb-review/references/findings-schema.json",
        "owner": "review-skill-maintainers",
        "reason": "Schemas differ where KB review includes KB-specific structural-quality review expectations."
      },
      {
        "id": "review-persona-catalog",
        "left": ".github/skills/ce-review/references/persona-catalog.md",
        "right": ".github/skills/kb-review/references/persona-catalog.md",
        "owner": "review-skill-maintainers",
        "reason": "Persona catalogs differ because KB review replaces maintainability with thermonuclear structural-quality review."
      },
      {
        "id": "review-post-review-flow",
        "left": ".github/skills/ce-review/references/post-review-flow.md",
        "right": ".github/skills/kb-review/references/post-review-flow.md",
        "owner": "review-skill-maintainers",
        "reason": "Post-review flow differs around KB completion gates and CE generalized follow-up handling."
      },
      {
        "id": "review-output-template",
        "left": ".github/skills/ce-review/references/review-output-template.md",
        "right": ".github/skills/kb-review/references/review-output-template.md",
        "owner": "review-skill-maintainers",
        "reason": "Output templates differ where KB review reports KB-specific structural-quality and completion-gate findings."
      },
      {
        "id": "review-process",
        "left": ".github/skills/ce-review/references/review-process.md",
        "right": ".github/skills/kb-review/references/review-process.md",
        "owner": "review-skill-maintainers",
        "reason": "Review process differs because KB review runs the KB-specific thermonuclear structural-quality lane."
      },
      {
        "id": "review-subagent-template",
        "left": ".github/skills/ce-review/references/subagent-template.md",
        "right": ".github/skills/kb-review/references/subagent-template.md",
        "owner": "review-skill-maintainers",
        "reason": "Subagent templates differ where KB review injects KB-specific reviewer personas and instructions."
      },
      {
        "id": "document-review-findings-schema-ce",
        "left": ".github/skills/ce-review/references/findings-schema.json",
        "right": ".github/skills/document-review/references/findings-schema.json",
        "owner": "review-skill-maintainers",
        "reason": "document-review findings target plan/document issues, while ce-review findings target code-review issues."
      },
      {
        "id": "document-review-findings-schema-kb",
        "left": ".github/skills/kb-review/references/findings-schema.json",
        "right": ".github/skills/document-review/references/findings-schema.json",
        "owner": "review-skill-maintainers",
        "reason": "document-review findings target plan/document issues, while kb-review findings include KB completion and structural-quality code-review issues."
      },
      {
        "id": "document-review-output-template-ce",
        "left": ".github/skills/ce-review/references/review-output-template.md",
        "right": ".github/skills/document-review/references/review-output-template.md",
        "owner": "review-skill-maintainers",
        "reason": "document-review output is requirements/plan-centered; ce-review output is code-diff-centered."
      },
      {
        "id": "document-review-output-template-kb",
        "left": ".github/skills/kb-review/references/review-output-template.md",
        "right": ".github/skills/document-review/references/review-output-template.md",
        "owner": "review-skill-maintainers",
        "reason": "document-review output is requirements/plan-centered; kb-review output is KB completion and code-diff-centered."
      },
      {
        "id": "document-review-subagent-template-ce",
        "left": ".github/skills/ce-review/references/subagent-template.md",
        "right": ".github/skills/document-review/references/subagent-template.md",
        "owner": "review-skill-maintainers",
        "reason": "document-review subagents evaluate document quality personas; ce-review subagents evaluate code-review personas."
      },
      {
        "id": "document-review-subagent-template-kb",
        "left": ".github/skills/kb-review/references/subagent-template.md",
        "right": ".github/skills/document-review/references/subagent-template.md",
        "owner": "review-skill-maintainers",
        "reason": "document-review subagents evaluate document quality personas; kb-review subagents include KB structural-quality code-review personas."
      }
    ],
    "reference_roots": [
      {
        "id": "ce-review",
        "path": ".github/skills/ce-review/references"
      },
      {
        "id": "kb-review",
        "path": ".github/skills/kb-review/references"
      },
      {
        "id": "document-review",
        "path": ".github/skills/document-review/references"
      }
    ]
  },
  "sync_targets": [
    {
      "id": "working",
      "label": "working repo",
      "path": ".github/skills",
      "classification": "source",
      "required": true
    },
    {
      "id": "codex-global",
      "label": "Codex global",
      "path": "~/.codex/skills",
      "classification": "required",
      "required": true
    },
    {
      "id": "copilot-global",
      "label": "Copilot global",
      "path": "~/.copilot/skills",
      "classification": "required",
      "required": true
    },
    {
      "id": "agents-global",
      "label": "shared agents global",
      "path": "~/.agents/skills",
      "classification": "required",
      "required": true
    }
  ]
}
