{
  "name": "working-skill-repo",
  "version": "0.1.0",
  "description": "Portable KB workflow skill bundle installer for Codex and GitHub Copilot.",
  "type": "module",
  "bin": {
    "working-skill-repo": "bin/kb-install.mjs",
    "kb-install": "bin/kb-install.mjs"
  },
  "files": [
    "AGENTS.md",
    "README.md",
    "LICENSE",
    "bin/",
    ".github/agents/",
    ".github/skills/",
    "!.github/skills/**/__pycache__/",
    "!.github/skills/**/*.pyc",
    ".github/copilot-instructions.md",
    ".github/instructions/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "test:install:core": "node ./bin/kb-install.mjs --target all --profile core --install-root ./.tmp/node-install-core --yes",
    "test:install:full": "node ./bin/kb-install.mjs --target all --profile full --install-root ./.tmp/node-install-full --yes"
  },
  "license": "MIT"
}
