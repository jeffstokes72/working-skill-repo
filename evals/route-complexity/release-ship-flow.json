{
  "id": "release-ship-flow",
  "platforms": ["codex", "ghcp"],
  "prompt": "This reviewed KB manifest has a passing complete-to-ship gate. Check it in, push the topic branch, and open or update its PR.",
  "repo_state": "Implementation and kb-complete are done; checked-in PR delivery remains.",
  "expected": {
    "route": "kb-complete",
    "complexity_tier": "standard",
    "max_user_questions": 1,
    "artifacts": ["audited shipping scope", "commit", "pushed branch", "PR URL"],
    "proof": ["complete-to-ship gate", "release checks pass", "local and upstream SHAs match"]
  },
  "complexity_signals": {
    "subsystem_count": 2,
    "uncertainty": 1,
    "user_visible": false,
    "data_auth_security_risk": 1,
    "external_dependency": true,
    "verification_surface": "full",
    "rollback_difficulty": 2,
    "expected_duration_hours": 3
  },
  "guards": ["wrong-lane"]
}
